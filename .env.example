# ── Playwright ──────────────────────────────────────────────────────────────
USE_PLAYWRIGHT=true
PLAYWRIGHT_TIMEOUT=15
MAX_CONCURRENT_PLAYWRIGHT=3

# ── HTTP ─────────────────────────────────────────────────────────────────────
HTTP_TIMEOUT=10

# ── Extractor limits ─────────────────────────────────────────────────────────
RICH_TEXT_MAX_CHARS=800
ABOUT_TEXT_MAX_CHARS=300
MAX_DOMAINS_PER_REQUEST=100

# ── Server ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
